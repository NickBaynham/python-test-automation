# Local overrides. Copy to .env (git ignored); docker compose and the
# platform both read it, so port and URL pairs stay together.
# Uncomment and change pairs together.

#SAMPLEAPP_PORT=3100
#TP_UI_BASE_URL=http://localhost:3100

#SAMPLEAPI_PORT=8100
#TP_API_BASE_URL=http://localhost:8100

#MONGO_PORT=27100
#TP_MONGO_URL=mongodb://localhost:27100
#TP_MONGO_DATABASE=sampledb

#TP_ENVIRONMENT=local
#TP_TARGET_MODE=docker
